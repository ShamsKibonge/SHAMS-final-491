PORT=5000

# OpenSearch connection.
# Use either a direct OpenSearch endpoint or an OpenSearch Dashboards URL when OPENSEARCH_MODE=dashboards_proxy.
OPENSEARCH_NODE=https://opensearch.example.local
OPENSEARCH_USERNAME=replace_me
OPENSEARCH_PASSWORD=replace_me
OPENSEARCH_MODE=direct
OPENSEARCH_INDEX=arkime_sessions3-*
OPENSEARCH_INDEX_PATTERN_ID=arkime_sessions3-*

# MantisBT REST API.
MANTIS_URL=https://mantis.example.local
MANTIS_API_TOKEN=replace_me
MANTIS_USERNAME=replace_me
MANTIS_CONTEXT_MAX_PAGES=5
MANTIS_CONTEXT_PAGE_SIZE=100
MANTIS_CONTEXT_MIN_SCORE=2
MANTIS_CONTEXT_LOOKBACK_DAYS=30

# AI-assisted case analysis.
OPENAI_API_KEY=replace_me
OPENAI_CASE_MANAGER_MODEL=gpt-4o
CASE_MANAGER_V1_MAX_AI_CASES=5
CASE_MANAGER_V1_MAX_PIVOTS=2
